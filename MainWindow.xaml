<Window x:Class="LogAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="{DynamicResource AppTitle}"
        ui:WindowHelper.UseModernWindowStyle="True"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        Height="720" Width="1200"
        MinHeight="600" MinWidth="1000">
    <Window.Resources>
        <Style x:Key="SectionGroupBoxStyle" TargetType="{x:Type GroupBox}">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GroupBox}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border
                                Grid.Row="1"
                                Margin="0,6,0,0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Content"/>
                            </Border>

                            <Border Grid.Row="0"
                                    Margin="10,0,0,0"
                                    Padding="6,0"
                                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top">
                                <ContentPresenter
                                    ContentSource="Header"
                                    VerticalAlignment="Center"
                                    TextElement.Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionDataGridStyle" TargetType="{x:Type DataGrid}">
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>
    <DockPanel>

        <!-- ===== Menu ===== -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{DynamicResource MenuFile}">
                <MenuItem Header="{DynamicResource MenuExit}" x:Name="MenuExit"/>
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuTools}">
                <MenuItem Header="{DynamicResource MenuOpenSettings}" x:Name="MenuOpenSettings"/>
                <Separator Visibility="Collapsed"/>
                <MenuItem Header="{DynamicResource MenuTimeFormat}" Visibility="Collapsed">
                    <MenuItem Header="{DynamicResource TimeFormat24}" x:Name="MenuTimeFormat24" IsCheckable="True"/>
                    <MenuItem Header="{DynamicResource TimeFormat12}" x:Name="MenuTimeFormat12" IsCheckable="True"/>
                </MenuItem>
                <MenuItem Header="{DynamicResource MenuClearPreview}" x:Name="MenuClearPreview" Visibility="Collapsed"/>
                <Separator Visibility="Collapsed"/>
                <MenuItem Header="{DynamicResource MenuTheme}" x:Name="MenuTheme" Visibility="Collapsed">
                    <MenuItem Header="{DynamicResource ThemeLight}" x:Name="MenuThemeLight" IsCheckable="True"/>
                    <MenuItem Header="{DynamicResource ThemeDark}" x:Name="MenuThemeDark" IsCheckable="True"/>
                </MenuItem>
                <Separator Visibility="Collapsed"/>
                <MenuItem Header="{DynamicResource MenuLanguage}" x:Name="MenuLanguage" Visibility="Collapsed">
                    <MenuItem Header="{DynamicResource LangEnglish}" x:Name="MenuLangEnglish" IsCheckable="True"/>
                    <MenuItem Header="{DynamicResource LangJapanese}" x:Name="MenuLangJapanese" IsCheckable="True"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{DynamicResource MenuHelp}">
                <MenuItem Header="{DynamicResource MenuAbout}" x:Name="MenuAbout"/>
            </MenuItem>
        </Menu>

        <!-- ===== Toolbar ===== -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="{DynamicResource BtnCollect}" x:Name="BtnCollect" Padding="10,4" Margin="2"/>
                <Button Content="{DynamicResource BtnAnalyze}" x:Name="BtnAnalyze" Padding="10,4" Margin="2"/>
                <Button Content="{DynamicResource BtnRunAll}" x:Name="BtnRunAll" Padding="10,4" Margin="2"/>
                <Button Content="{DynamicResource BtnExport}" x:Name="BtnExport" Padding="10,4" Margin="2"/>
                <Separator/>
                <Button Content="{DynamicResource BtnCancel}" x:Name="BtnCancel" Padding="10,4" Margin="2" IsEnabled="False"/>
            </ToolBar>
        </ToolBarTray>

        <!-- ===== StatusBar ===== -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{DynamicResource StatusReady}" x:Name="StatusText"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{DynamicResource LabelEvents}"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="0" x:Name="StatusEventCount"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <ProgressBar x:Name="StatusProgress" Width="180" Height="14" Minimum="0" Maximum="100" Value="0"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="0%" x:Name="StatusProgressText" Margin="6,0,0,0"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ===== Main Layout ===== -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="220"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Left: Filters / Inputs ===== -->
            <ScrollViewer Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">

                    <GroupBox Header="{DynamicResource GroupTarget}" Margin="0,0,0,10" Style="{StaticResource SectionGroupBoxStyle}">
                        <StackPanel Margin="10">
                            <TextBlock Text="{DynamicResource LabelMachine}" FontWeight="SemiBold"/>
                            <DockPanel Margin="0,6,0,0">
                                <TextBox x:Name="TxtMachineName" Width="220" />
                                <Button x:Name="BtnTestConnection"
                                        Content="{DynamicResource BtnTest}"
                                        Margin="6,0,0,0"
                                        Padding="10,3"
                                        FontSize="11"
                                        MinHeight="30"
                                        VerticalContentAlignment="Center"/>
                            </DockPanel>
                            <TextBlock Text="{DynamicResource LabelMvpHint}" Opacity="0.7" Margin="0,4,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{DynamicResource GroupTimeRange}" Margin="0,0,0,10" Style="{StaticResource SectionGroupBoxStyle}">
                        <StackPanel Margin="10">
                            <TextBlock Text="{DynamicResource LabelStart}" />
                            <DatePicker x:Name="DpStart" Margin="0,4,0,8"/>
                            <TextBlock Text="{DynamicResource LabelEnd}" />
                            <DatePicker x:Name="DpEnd" Margin="0,4,0,0"/>

                            <Separator Margin="0,10,0,10"/>

                            <TextBlock Text="{DynamicResource LabelQuickRange}" FontWeight="SemiBold"/>
                            <WrapPanel Margin="0,6,0,0">
                                <Button x:Name="BtnQuick1h" Content="{DynamicResource BtnLast1h}" Margin="0,0,6,6" Padding="10,2"/>
                                <Button x:Name="BtnQuick24h" Content="{DynamicResource BtnLast24h}" Margin="0,0,6,6" Padding="10,2"/>
                                <Button x:Name="BtnQuick7d" Content="{DynamicResource BtnLast7d}" Margin="0,0,6,6" Padding="10,2"/>
                                <Button x:Name="BtnQuick30d" Content="{DynamicResource BtnLast30d}" Margin="0,0,6,6" Padding="10,2"/>
                            </WrapPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{DynamicResource GroupLogs}" Margin="0,0,0,8" FontSize="12" Style="{StaticResource SectionGroupBoxStyle}">
                        <StackPanel Margin="6">
                            <CheckBox x:Name="ChkSystem" Content="{DynamicResource LogSystem}" IsChecked="True" Margin="0,0,0,2" FontSize="11"/>
                            <CheckBox x:Name="ChkApplication" Content="{DynamicResource LogApplication}" IsChecked="True" Margin="0,0,0,2"/>
                            <CheckBox x:Name="ChkSetup" Content="{DynamicResource LogSetup}" IsChecked="True" Margin="0,0,0,2"/>
                            <CheckBox x:Name="ChkSecurity" Content="{DynamicResource LogSecurity}" IsChecked="True" Margin="0,0,0,2"/>
                            <CheckBox x:Name="ChkForwardedEvents" Content="{DynamicResource LogForwardedEvents}" IsChecked="True"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{DynamicResource GroupLevels}" Margin="0,0,0,8" FontSize="12" Style="{StaticResource SectionGroupBoxStyle}">
                        <Grid Margin="6">
                            <UniformGrid Columns="2">
                                <CheckBox x:Name="ChkCritical" Content="{DynamicResource LevelCritical}" Margin="0,0,8,2" FontSize="11"/>
                                <CheckBox x:Name="ChkError" Content="{DynamicResource LevelError}" IsChecked="True" Margin="0,0,0,2" FontSize="11"/>
                                <CheckBox x:Name="ChkWarning" Content="{DynamicResource LevelWarning}" IsChecked="True" Margin="0,0,8,0" FontSize="11"/>
                                <CheckBox x:Name="ChkInformation" Content="{DynamicResource LevelInformation}" Margin="0,0,0,0" FontSize="11"/>
                            </UniformGrid>
                        </Grid>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>

            <!-- ===== Center: Preview Grid ===== -->
            <GroupBox Grid.Row="0" Grid.Column="1" Header="{DynamicResource GroupPreviewEvents}" Margin="10,10,5,10" Style="{StaticResource SectionGroupBoxStyle}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource LabelSort}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="CmbSort" Width="160" SelectedIndex="0">
                            <ComboBoxItem Content="{DynamicResource SortTimeDesc}"/>
                            <ComboBoxItem Content="{DynamicResource SortTimeAsc}"/>
                            <ComboBoxItem Content="{DynamicResource SortLevel}"/>
                            <ComboBoxItem Content="{DynamicResource SortProvider}"/>
                            <ComboBoxItem Content="{DynamicResource SortEventId}"/>
                        </ComboBox>
                        <Separator Margin="10,0,10,0"/>
                        <TextBlock Text="{DynamicResource LabelTopN}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="TxtTopN" Width="102" Text="500"/>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              x:Name="GridPreview"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              Style="{StaticResource SectionDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource ColTime}" Width="160" Binding="{Binding TimeDisplay}"/>
                            <DataGridTextColumn Header="{DynamicResource ColLevel}" Width="90" Binding="{Binding Level}"/>
                            <DataGridTextColumn Header="{DynamicResource ColProvider}" Width="200" Binding="{Binding ProviderName}"/>
                            <DataGridTextColumn Header="{DynamicResource ColEventId}" Width="80" Binding="{Binding Id}"/>
                            <DataGridTextColumn Header="{DynamicResource ColMessage}" Width="*" Binding="{Binding MessageShort}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                        <Setter Property="ToolTip" Value="{Binding Message}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>

            <!-- ===== Right: Details / Summary / Aggregation ===== -->
            <GroupBox Grid.Row="0" Grid.Column="2" Header="{DynamicResource GroupDetailsSummary}" Margin="5,10,10,10" Style="{StaticResource SectionGroupBoxStyle}">
                <Grid Margin="10">
                    <TabControl x:Name="TabRight">
                        <TabItem Header="{DynamicResource TabEventDetail}">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="BtnCopyEventJson" Content="{DynamicResource BtnCopyJson}" Padding="10,2" Margin="0,0,6,0"/>
                                    <Button x:Name="BtnCopyMessage" Content="{DynamicResource BtnCopyMessage}" Padding="10,2"/>
                                </StackPanel>

                                <TextBox Grid.Row="1"
                                         x:Name="TxtEventDetail"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"/>
                            </Grid>
                        </TabItem>

                        <TabItem Header="{DynamicResource TabSummary}">
                            <Grid Margin="8">
                                <TextBox x:Name="TxtSummary"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"/>
                            </Grid>
                        </TabItem>

                        <TabItem Header="解析">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="BtnRefreshAnalysis" Content="解析を更新" Padding="10,2" Margin="0,0,8,0"/>
                                    <Button x:Name="BtnOpenAnalysisWindow" Content="解析ウィンドウを開く" Padding="10,2"/>
                                </StackPanel>

                                <TextBlock Grid.Row="1"
                                           x:Name="TxtAnalysisStatus"
                                           Text="解析はまだ実行されていません。"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="2"
                                           Text="解析結果は別ウィンドウで表示されます。"
                                           Opacity="0.7"/>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </GroupBox>

            <!-- ===== Bottom: Output files + Log console ===== -->
            <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="10,0,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <GroupBox Header="{DynamicResource GroupOutputs}" Grid.Column="0" Margin="0,0,8,0" Style="{StaticResource SectionGroupBoxStyle}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListBox x:Name="ListOutputs" Grid.Row="0"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button x:Name="BtnOpenSelectedOutput" Content="{DynamicResource BtnOpen}" Padding="10,2" Margin="0,0,6,0"/>
                            <Button x:Name="BtnOpenOutputFolder" Content="{DynamicResource BtnOpenFolder}" Padding="10,2"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="{DynamicResource GroupRunLog}" Grid.Column="1" Style="{StaticResource SectionGroupBoxStyle}">
                    <Grid Margin="10">
                        <TextBox x:Name="TxtRunLog"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"/>
                    </Grid>
                </GroupBox>
            </Grid>

        </Grid>
    </DockPanel>
</Window>
