<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FF1B1E22"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FF252A31"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#FFEAF0F6"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#FF555555"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FF2E343C"/>
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#FFF3F7FB"/>
    <SolidColorBrush x:Key="GridHeaderBackgroundBrush" Color="#FF323843"/>
    <SolidColorBrush x:Key="GridRowBackgroundBrush" Color="#FF252A31"/>
    <SolidColorBrush x:Key="GridAltRowBackgroundBrush" Color="#FF2B3139"/>
    <SolidColorBrush x:Key="GridSelectionBackgroundBrush" Color="#FF335C87"/>
    <SolidColorBrush x:Key="AnalysisProviderColor1" Color="#FF2E8B57"/>
    <SolidColorBrush x:Key="AnalysisProviderColor2" Color="#FF7BC67E"/>
    <SolidColorBrush x:Key="AnalysisProviderColor3" Color="#FFA0A0A0"/>
    <SolidColorBrush x:Key="AnalysisProviderColor4" Color="#FFB5B5B5"/>
    <SolidColorBrush x:Key="AnalysisProviderColor5" Color="#FFC8C8C8"/>
    <SolidColorBrush x:Key="AnalysisProviderColor6" Color="#FFD8D8D8"/>
    <SolidColorBrush x:Key="AnalysisProviderColor7" Color="#FFE3E3E3"/>
    <SolidColorBrush x:Key="AnalysisProviderColor8" Color="#FFECECEC"/>
    <SolidColorBrush x:Key="AnalysisProviderColorOther" Color="#FFE0E0E0"/>
    <StaticResource x:Key="PanelBorderBrush" ResourceKey="BorderBrush"/>
    <x:Array x:Key="ChartColorPaletteSwatches" Type="{x:Type SolidColorBrush}">
        <StaticResource ResourceKey="GridHeaderBackgroundBrush"/>
        <StaticResource ResourceKey="GridSelectionBackgroundBrush"/>
        <StaticResource ResourceKey="InputForegroundBrush"/>
        <StaticResource ResourceKey="ForegroundBrush"/>
        <StaticResource ResourceKey="AnalysisProviderColor1"/>
        <StaticResource ResourceKey="AnalysisProviderColor2"/>
        <StaticResource ResourceKey="AnalysisProviderColor3"/>
        <StaticResource ResourceKey="AnalysisProviderColor4"/>
    </x:Array>
    <SolidColorBrush x:Key="AppTextBrush" Color="#FFE6E6E6"/>
    <SolidColorBrush x:Key="App.Dark.Bg" Color="#FF2B2F36"/>
    <SolidColorBrush x:Key="App.Dark.Fg" Color="#FFE6E6E6"/>
    <SolidColorBrush x:Key="App.Dark.Border" Color="#FF555555"/>
    <SolidColorBrush x:Key="App.Dark.HoverBg" Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="App.Dark.HoverFg" Color="#FF111111"/>
    <SolidColorBrush x:Key="App.Dark.DisabledFg" Color="#FF888888"/>
    <SolidColorBrush x:Key="App.Dark.PanelBg" Color="#FF23272E"/>
    <SolidColorBrush x:Key="DarkBgBrush" Color="#FF2B2F36"/>
    <SolidColorBrush x:Key="DarkFgBrush" Color="#FFE6E6E6"/>
    <SolidColorBrush x:Key="LightBgBrush" Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="LightFgBrush" Color="#FF111111"/>
    <SolidColorBrush x:Key="DisabledFgBrush" Color="#FF888888"/>
    <SolidColorBrush x:Key="MenuItemTopLevelNormalBackgroundBrush" Color="#00000000"/>
    <SolidColorBrush x:Key="MenuItemSubmenuNormalBackgroundBrush" Color="#FF2B2F36"/>
    <SolidColorBrush x:Key="MenuItemNormalForegroundBrush" Color="#FFE6E6E6"/>
    <SolidColorBrush x:Key="MenuItemHoverBackgroundBrush" Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="MenuItemHoverForegroundBrush" Color="#FF111111"/>
    <Color x:Key="{x:Static SystemColors.WindowColorKey}">#2B2F36</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF2B2F36"/>
    <Color x:Key="{x:Static SystemColors.WindowTextColorKey}">#E6E6E6</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FFE6E6E6"/>
    <Color x:Key="{x:Static SystemColors.ControlColorKey}">#2B2F36</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF2B2F36"/>
    <Color x:Key="{x:Static SystemColors.ControlTextColorKey}">#E6E6E6</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FFE6E6E6"/>
    <Color x:Key="{x:Static SystemColors.HighlightColorKey}">#F0F0F0</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FFF0F0F0"/>
    <Color x:Key="{x:Static SystemColors.HighlightTextColorKey}">#111111</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FF111111"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FF111111"/>
    <Color x:Key="{x:Static SystemColors.MenuColorKey}">#2B2F36</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FF2B2F36"/>
    <Color x:Key="{x:Static SystemColors.MenuTextColorKey}">#E6E6E6</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFE6E6E6"/>
    <Color x:Key="{x:Static SystemColors.MenuHighlightColorKey}">#F0F0F0</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#FFF0F0F0"/>
    <Color x:Key="{x:Static SystemColors.MenuBarColorKey}">#2B2F36</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#FF2B2F36"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#FF888888"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
    </Style>

    <Style TargetType="Control">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="box"
                                Width="16"
                                Height="16"
                                VerticalAlignment="Center"
                                Background="{DynamicResource InputBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2">
                            <Path x:Name="check"
                                  Data="M 3 8 L 6.5 11.5 L 13 4.5"
                                  Stroke="{DynamicResource InputForegroundBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Visibility="Collapsed"/>
                        </Border>

                        <ContentPresenter Grid.Column="1"
                                          Margin="6,0,0,0"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource GridSelectionBackgroundBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="box" Property="Opacity" Value="0.65"/>
                            <Setter TargetName="check" Property="Opacity" Value="0.75"/>
                            <Setter Property="Opacity" Value="0.75"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Width="16" Height="16" VerticalAlignment="Center">
                            <Ellipse Stroke="{TemplateBinding Foreground}"
                                     StrokeThickness="1.5"
                                     Fill="{DynamicResource InputBackgroundBrush}"/>
                            <Ellipse x:Name="InnerDot"
                                     Width="8"
                                     Height="8"
                                     Fill="{TemplateBinding Foreground}"
                                     Visibility="Collapsed"/>
                        </Grid>

                        <ContentPresenter Grid.Column="1"
                                          Margin="6,0,0,0"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="InnerDot" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource App.Dark.Bg}"/>
        <Setter Property="Foreground" Value="{DynamicResource App.Dark.Fg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource App.Dark.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Dark.HoverBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource App.Dark.HoverFg}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Dark.HoverBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource App.Dark.HoverFg}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource App.Dark.Bg}"/>
                <Setter Property="Foreground" Value="{DynamicResource App.Dark.DisabledFg}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource App.Dark.Border}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="{x:Static ToolBar.ButtonStyleKey}"
           TargetType="Button"
           BasedOn="{StaticResource {x:Type Button}}"/>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource App.Dark.Bg}"/>
        <Setter Property="Foreground" Value="{DynamicResource App.Dark.Fg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource App.Dark.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4,2"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Dark.HoverBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource App.Dark.HoverFg}"/>
            </Trigger>
            <Trigger Property="IsDropDownOpen" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Dark.HoverBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource App.Dark.HoverFg}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource App.Dark.DisabledFg}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource App.Dark.Fg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource App.Dark.Border}"/>
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="TextElement.Foreground" Value="{Binding RelativeSource={RelativeSource Self}, Path=Foreground}"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Dark.HoverBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource App.Dark.HoverFg}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Dark.HoverBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource App.Dark.HoverFg}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource App.Dark.DisabledFg}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DarkCalendarDayButtonStyle" TargetType="primitives:CalendarDayButton">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridHeaderBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridSelectionBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource GridSelectionBackgroundBrush}"/>
            </Trigger>
            <Trigger Property="IsToday" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource GridSelectionBackgroundBrush}"/>
                <Setter Property="BorderThickness" Value="2"/>
            </Trigger>
            <Trigger Property="IsInactive" Value="True">
                <Setter Property="Foreground" Value="#FF9AA5B2"/>
            </Trigger>
            <Trigger Property="IsBlackedOut" Value="True">
                <Setter Property="Foreground" Value="#FF7A8592"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DarkCalendarButtonStyle" TargetType="primitives:CalendarButton">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridHeaderBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridSelectionBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DarkCalendarColumnHeaderStyle" TargetType="primitives:CalendarButton" BasedOn="{StaticResource DarkCalendarButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource GridHeaderBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
    </Style>

    <Style x:Key="DarkCalendarItemStyle" TargetType="primitives:CalendarItem">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
    </Style>

    <Style x:Key="DarkCalendarStyle" TargetType="Calendar">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CalendarItemStyle" Value="{StaticResource DarkCalendarItemStyle}"/>
        <Setter Property="CalendarDayButtonStyle" Value="{StaticResource DarkCalendarDayButtonStyle}"/>
        <Setter Property="CalendarButtonStyle" Value="{StaticResource DarkCalendarButtonStyle}"/>
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="CalendarStyle" Value="{StaticResource DarkCalendarStyle}"/>
    </Style>

    <Style TargetType="primitives:DatePickerTextBox">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="Calendar" BasedOn="{StaticResource DarkCalendarStyle}"/>

    <Style TargetType="primitives:CalendarItem" BasedOn="{StaticResource DarkCalendarItemStyle}"/>

    <Style TargetType="primitives:CalendarDayButton" BasedOn="{StaticResource DarkCalendarDayButtonStyle}"/>

    <Style TargetType="primitives:CalendarButton" BasedOn="{StaticResource DarkCalendarButtonStyle}"/>

    <Style TargetType="GroupBox">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="Menu">
        <Setter Property="Background" Value="{DynamicResource App.Dark.Bg}"/>
        <Setter Property="Foreground" Value="{DynamicResource App.Dark.Fg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource App.Dark.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource App.Dark.Fg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource App.Dark.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="TextElement.Foreground" Value="{Binding RelativeSource={RelativeSource Self}, Path=Foreground}"/>
        <Style.Triggers>
            <Trigger Property="Role" Value="{x:Static MenuItemRole.TopLevelHeader}">
                <Setter Property="Background" Value="Transparent"/>
            </Trigger>
            <Trigger Property="Role" Value="{x:Static MenuItemRole.TopLevelItem}">
                <Setter Property="Background" Value="Transparent"/>
            </Trigger>
            <Trigger Property="Role" Value="{x:Static MenuItemRole.SubmenuItem}">
                <Setter Property="Background" Value="{DynamicResource App.Dark.Bg}"/>
            </Trigger>
            <Trigger Property="Role" Value="{x:Static MenuItemRole.SubmenuHeader}">
                <Setter Property="Background" Value="{DynamicResource App.Dark.Bg}"/>
            </Trigger>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Dark.HoverBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource App.Dark.HoverFg}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource App.Dark.HoverFg}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Dark.HoverBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource App.Dark.HoverFg}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource App.Dark.HoverFg}"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Dark.HoverBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource App.Dark.HoverFg}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource App.Dark.HoverFg}"/>
            </Trigger>
            <Trigger Property="IsSubmenuOpen" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Dark.HoverBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource App.Dark.HoverFg}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource App.Dark.HoverFg}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource App.Dark.DisabledFg}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource App.Dark.DisabledFg}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ScrollViewer.Background" Value="{DynamicResource PanelBackgroundBrush}"/>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Background" Value="{DynamicResource DarkBgBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource DarkFgBrush}"/>
        <Setter Property="TextElement.Foreground" Value="{Binding RelativeSource={RelativeSource Self}, Path=Foreground}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource LightBgBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource LightFgBrush}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource LightFgBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource LightBgBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource LightFgBrush}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource LightFgBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource DisabledFgBrush}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource DisabledFgBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ToolBar">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource App.Dark.Fg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource App.Dark.Border}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="RowBackground" Value="{DynamicResource GridRowBackgroundBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridAltRowBackgroundBrush}"/>
        <Setter Property="HeadersVisibility" Value="All"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource GridHeaderBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="{DynamicResource GridRowBackgroundBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridSelectionBackgroundBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>
</ResourceDictionary>



