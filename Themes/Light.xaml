<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFF4F6F8"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#FF1F2933"/>
    <SolidColorBrush x:Key="AppTextBrush" Color="#FF1F2933"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#FFD0D7DE"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#FF1F2933"/>
    <SolidColorBrush x:Key="GridHeaderBackgroundBrush" Color="#FFE8EDF2"/>
    <SolidColorBrush x:Key="OutputListSelectionBrush" Color="#FFE8EDF2"/>
    <SolidColorBrush x:Key="GridRowBackgroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="GridAltRowBackgroundBrush" Color="#FFF5F8FB"/>
    <SolidColorBrush x:Key="GridSelectionBackgroundBrush" Color="#FFCCE3FF"/>
    <SolidColorBrush x:Key="AnalysisProviderColor1" Color="#FF2E8B57"/>
    <SolidColorBrush x:Key="AnalysisProviderColor2" Color="#FF6FBE73"/>
    <SolidColorBrush x:Key="AnalysisProviderColor3" Color="#FF8FA1B3"/>
    <SolidColorBrush x:Key="AnalysisProviderColor4" Color="#FFA8B7C5"/>
    <SolidColorBrush x:Key="AnalysisProviderColor5" Color="#FFC1CCD7"/>
    <SolidColorBrush x:Key="AnalysisProviderColor6" Color="#FFD5DDE5"/>
    <SolidColorBrush x:Key="AnalysisProviderColor7" Color="#FFE3E8EE"/>
    <SolidColorBrush x:Key="AnalysisProviderColor8" Color="#FFEEF2F6"/>
    <SolidColorBrush x:Key="AnalysisProviderColorOther" Color="#FFD2D8DF"/>
    <StaticResource x:Key="PanelBorderBrush" ResourceKey="BorderBrush"/>
    <x:Array x:Key="ChartColorPaletteSwatches" Type="{x:Type SolidColorBrush}">
        <StaticResource ResourceKey="GridHeaderBackgroundBrush"/>
        <StaticResource ResourceKey="GridSelectionBackgroundBrush"/>
        <StaticResource ResourceKey="InputForegroundBrush"/>
        <StaticResource ResourceKey="ForegroundBrush"/>
        <StaticResource ResourceKey="AnalysisProviderColor1"/>
        <StaticResource ResourceKey="AnalysisProviderColor2"/>
        <StaticResource ResourceKey="AnalysisProviderColor3"/>
        <StaticResource ResourceKey="AnalysisProviderColor4"/>
    </x:Array>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
    </Style>

    <Style TargetType="Control">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="primitives:DatePickerTextBox">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="Calendar">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="primitives:CalendarItem">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="primitives:CalendarDayButton">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridSelectionBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}"/>
            </Trigger>
            <Trigger Property="IsToday" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource GridSelectionBackgroundBrush}"/>
                <Setter Property="BorderThickness" Value="2"/>
            </Trigger>
            <Trigger Property="IsInactive" Value="True">
                <Setter Property="Opacity" Value="0.7"/>
            </Trigger>
            <Trigger Property="IsBlackedOut" Value="True">
                <Setter Property="Opacity" Value="0.45"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="primitives:CalendarButton">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="GroupBox">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="Menu">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridHeaderBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ToolBar">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridHeaderBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="RowBackground" Value="{DynamicResource GridRowBackgroundBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridAltRowBackgroundBrush}"/>
        <Setter Property="HeadersVisibility" Value="All"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource GridHeaderBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="{DynamicResource GridRowBackgroundBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource GridSelectionBackgroundBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>
</ResourceDictionary>



